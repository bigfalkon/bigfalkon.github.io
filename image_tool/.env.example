# Firebase Service Account JSON dosyasının yolu
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni özel anahtar oluştur
FIREBASE_SERVICE_ACCOUNT=./service-account.json

# ImgBB API Anahtarı (yükleme için gerekli)
# https://api.imgbb.com/ adresinden ücretsiz alabilirsiniz
IMGBB_API_KEY=your_imgbb_api_key_here

# Firestore koleksiyon adları (genellikle değiştirmenize gerek yok)
CHARACTERS_COLLECTION=characters
DISMISSED_COLLECTION=dismissed
